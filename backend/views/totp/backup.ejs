<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hunt-Hub | Use Backup Code</title>
    <link rel="stylesheet" href="/css/style.css?v=1" />
  </head>
  <body class="centered-page">
    <div class="card centered-card">
      <h1>Hunt-Hub</h1>
      <p>Enter a backup code</p>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form action="/totp/backup" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label for="code">Backup Code</label>
          <input
            type="text"
            id="code"
            name="code"
            placeholder="XXXX-XXXX"
            autocomplete="off"
            spellcheck="false"
            required
            autofocus
          />
        </div>
        <button type="submit" class="btn-confirm btn-full">Verify</button>
      </form>

      <form action="/totp" method="GET" style="margin-top: 1rem;">
        <button type="submit" class="btn-cancel btn-full">Use authenticator app instead</button>
      </form>
    </div>
  </body>
</html>
