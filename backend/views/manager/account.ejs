<div style="margin-bottom: 2rem;">
  <h2 style="margin: 0;">My Account</h2>
</div>

<!-- ── Account Info ───────────────────────────────────────────────────────── -->
<article>
  <dl>
    <dt>First Name</dt>
    <dd><%= fullUser.firstName %></dd>

    <dt>Last Name</dt>
    <dd><%= fullUser.lastName %></dd>

    <dt>Email</dt>
    <dd><%= fullUser.email %></dd>

    <dt>Role</dt>
    <dd style="text-transform: capitalize;"><%= fullUser.role %></dd>
  </dl>
</article>

<!-- ── Change Password ────────────────────────────────────────────────────── -->
<article>
  <header><strong>Password</strong></header>

  <% if (error) { %>
    <p style="color: var(--pico-color-red-500);"><%= error %></p>
  <% } %>

  <% if (success) { %>
    <p style="color: var(--pico-color-green-500);"><%= success %></p>
  <% } %>

  <button class="outline" data-dialog="change-password-dialog">
    Change Password
  </button>
</article>

<!-- ── Change Password Dialog ────────────────────────────────────────────── -->
<dialog id="change-password-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" data-close-dialog="change-password-dialog"></button>
      <h3>Change Password</h3>
    </header>
    <form action="/manager/account/password" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Current Password
        <input type="password" name="oldPassword" required />
      </label>
      <label>
        New Password
        <input type="password" id="new-password" name="newPassword" required minlength="8" />
        <ul id="pw-hints" style="list-style:none; padding:0; margin:4px 0 0; font-size:0.82rem;">
          <li id="hint-length"  style="color:#6b7280">✓ At least 8 characters</li>
          <li id="hint-upper"   style="color:#6b7280">✓ One uppercase letter</li>
          <li id="hint-number"  style="color:#6b7280">✓ One number</li>
          <li id="hint-special" style="color:#6b7280">✓ One special character</li>
        </ul>
      </label>
      <label>
        Repeat New Password
        <input type="password" name="confirmPassword" required minlength="8" />
      </label>
      <footer>
        <button type="button" class="outline" data-close-dialog="change-password-dialog">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<script src="/js/password-validator.js"></script>

<!-- ── QGIS Connection ────────────────────────────────────────────────────── -->
<article>
  <header><strong>QGIS Connection</strong></header>

  <% if (newWfsToken) { %>
    <p style="color: var(--pico-color-green-500); font-weight: 600;">
      Token generated. Copy it now — it will not be shown again in full.
    </p>
    <div style="display:flex; gap:0.5rem; align-items:center; margin-bottom:1rem;">
      <input id="wfs-token-field" type="text" value="<%= newWfsToken %>" readonly
        style="flex:1; font-family:monospace; font-size:0.85rem;" />
      <button type="button" class="outline" onclick="copyWfsToken()">Copy</button>
    </div>
    <p style="font-size:0.85rem; color: var(--pico-color-slate-500);">
      In QGIS: Layer → Add WFS Layer → New → URL:
      <code><%= wfsBaseUrl %>?token=<%= newWfsToken %></code>
    </p>
  <% } else if (wfsToken) { %>
    <p>A token is active for this account.</p>
    <div style="display:flex; gap:0.5rem; align-items:center; margin-bottom:1rem;">
      <input id="wfs-token-field" type="password" value="<%= wfsToken %>" readonly
        style="flex:1; font-family:monospace; font-size:0.85rem;" />
      <button type="button" class="outline" id="wfs-toggle-btn" onclick="toggleWfsToken()">Show</button>
      <button type="button" class="outline" onclick="copyWfsToken()">Copy</button>
    </div>
  <% } else { %>
    <p>No token active. Generate one to connect QGIS to this estate.</p>
  <% } %>

  <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
    <% if (!wfsToken) { %>
      <form method="POST" action="/manager/account/wfs-token/generate">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit">Generate token</button>
      </form>
    <% } else { %>
      <form method="POST" action="/manager/account/wfs-token/generate">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="outline">Regenerate token</button>
      </form>
      <form method="POST" action="/manager/account/wfs-token/delete"
        onsubmit="return confirm('Delete the QGIS token? QGIS will lose access immediately.')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="outline" style="color:var(--pico-color-red-500);">Delete token</button>
      </form>
    <% } %>
  </div>
</article>

<script src="/js/wfs-token.js"></script>
