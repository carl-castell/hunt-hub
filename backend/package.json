{
  "name": "@hunt-hub/backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "dev": "nodemon --exec tsx src/index.ts",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage",
    "studio": "DRIZZLE_DRIVER=pg drizzle-kit studio",
    "db:gen": "drizzle-kit generate",
    "db:push": "DRIZZLE_DRIVER=pg drizzle-kit push",
    "db:push:neon": "DB_PROVIDER=neon drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:neon": "DB_PROVIDER=neon tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:reset:neon": "DB_PROVIDER=neon tsx src/db/reset.ts",
    "db:reset:test": "docker compose down db_test -v && docker compose up -d db_test && node -e \"console.log('Waiting for test DB...')\" && tsx -e \"setTimeout(()=>process.exit(0), 5000)\" && LOCAL_DATABASE_URL=\"postgres://app:app@localhost:5434/appdb_test\" tsx src/db/migrate.ts",
    "db:docker-reset": "docker compose down -v && docker compose up -d && node -e \"console.log('Waiting for DB...')\" && tsx -e \"setTimeout(()=>process.exit(0), 5000)\" && npm run db:migrate && npm run db:seed",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:neon": "DB_PROVIDER=neon SEED_MOCK_DATA=false tsx src/db/seed.ts",
    "db:analyze": "tsx scripts/analyze-queries.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@faker-js/faker": "^10.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tmcw/togeojson": "^7.1.2",
    "@trpc/server": "^11.17.0",
    "@xmldom/xmldom": "^0.9.10",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "nodemailer-mailgun-transport": "^2.1.5",
    "otpauth": "^9.5.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "shapefile": "^0.6.6",
    "sql.js": "^1.14.1",
    "wkx": "^0.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^6.4.16",
    "@types/nodemailer-mailgun-transport": "^1.4.6",
    "@types/qrcode": "^1.5.6",
    "@types/sql.js": "^1.4.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
