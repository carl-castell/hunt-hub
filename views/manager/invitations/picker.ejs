<style>
  .picker-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .picker-header h2 { margin: 0; }
  #stage-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--pico-background-color);
    border-top: 1px solid var(--pico-muted-border-color);
    padding: 0.75rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
    z-index: 100;
  }
</style>

<div class="picker-header">
  <h2>Select guests for <%= event.eventName %></h2>
  <p style="margin:0; font-size:0.85rem; color:var(--pico-muted-color);"><%= total %> available</p>
</div>

<article style="margin-bottom:5rem;">
  <div style="margin-bottom:1rem;">
    <input type="text" id="picker-search" name="search" placeholder="Search by name or group…"
      value="<%= search %>"
      style="margin:0; width:100%; max-width:320px;"
      hx-get="/manager/events/<%= event.id %>/invitations/new"
      hx-trigger="input changed delay:300ms"
      hx-target="#picker-body"
      hx-swap="innerHTML" />
  </div>

  <% if (guests.length === 0 && !search) { %>
    <p style="text-align:center; padding:2rem 0; color:var(--pico-muted-color); margin:0;">All guests have already been invited.</p>
  <% } else { %>
    <figure style="margin:0;">
      <table id="picker-table">
        <thead>
          <tr>
            <th></th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Date of Birth</th>
            <th>Rating</th>
            <th>Groups</th>
          </tr>
        </thead>
        <tbody id="picker-body">
          <%- include('./picker-rows') %>
        </tbody>
      </table>
    </figure>
  <% } %>
</article>

<!-- Stage form — populated by JS before submit -->
<form id="stage-form" method="POST" action="/manager/events/<%= event.id %>/invitations">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
</form>

<!-- Sticky bottom bar -->
<div id="stage-bar">
  <span style="color:var(--pico-muted-color);"><strong id="selected-count" style="color:inherit;">0</strong> selected</span>
  <button id="stage-btn" disabled>Stage</button>
</div>

<script src="/js/invitations.js"></script>
