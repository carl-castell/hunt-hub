<div style="margin-bottom: 2rem;">
  <h2 style="margin: 0;">My Account</h2>
</div>

<!-- ── Account Info ───────────────────────────────────────────────────────── -->
<article>
  <dl>
    <dt>First Name</dt>
    <dd><%= fullUser.firstName %></dd>

    <dt>Last Name</dt>
    <dd><%= fullUser.lastName %></dd>

    <dt>Email</dt>
    <dd><%= fullUser.email %></dd>

    <dt>Role</dt>
    <dd style="text-transform: capitalize;"><%= fullUser.role %></dd>
  </dl>
</article>

<!-- ── Change Password ────────────────────────────────────────────────────── -->
<article>
  <header><strong>Password</strong></header>

  <% if (error) { %>
    <p style="color: var(--pico-color-red-500);"><%= error %></p>
  <% } %>

  <% if (success) { %>
    <p style="color: var(--pico-color-green-500);"><%= success %></p>
  <% } %>

  <button class="outline" onclick="document.getElementById('change-password-dialog').showModal()">
    Change Password
  </button>
</article>

<!-- ── Change Password Dialog ────────────────────────────────────────────── -->
<dialog id="change-password-dialog">
  <article>
    <header>
      <button aria-label="Close" rel="prev" onclick="document.getElementById('change-password-dialog').close()"></button>
      <h3>Change Password</h3>
    </header>
    <form action="/manager/account/password" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Current Password
        <input type="password" name="oldPassword" required />
      </label>
      <label>
        New Password
        <input type="password" id="new-password" name="newPassword" required minlength="8" />
        <ul id="pw-hints" style="list-style:none; padding:0; margin:4px 0 0; font-size:0.82rem;">
          <li id="hint-length"  style="color:#6b7280">✓ At least 8 characters</li>
          <li id="hint-upper"   style="color:#6b7280">✓ One uppercase letter</li>
          <li id="hint-number"  style="color:#6b7280">✓ One number</li>
          <li id="hint-special" style="color:#6b7280">✓ One special character</li>
        </ul>
      </label>
      <label>
        Repeat New Password
        <input type="password" name="confirmPassword" required minlength="8" />
      </label>
      <footer>
        <button type="button" class="outline" onclick="document.getElementById('change-password-dialog').close()">Cancel</button>
        <button type="submit">Save</button>
      </footer>
    </form>
  </article>
</dialog>

<script>
  const pw = document.getElementById('new-password');
  const hl = document.getElementById('hint-length');
  const hu = document.getElementById('hint-upper');
  const hn = document.getElementById('hint-number');
  const hs = document.getElementById('hint-special');
  pw.addEventListener('input', function () {
    hl.style.color = pw.value.length >= 8            ? '#16a34a' : '#6b7280';
    hu.style.color = /[A-Z]/.test(pw.value)          ? '#16a34a' : '#6b7280';
    hn.style.color = /[0-9]/.test(pw.value)          ? '#16a34a' : '#6b7280';
    hs.style.color = /[^a-zA-Z0-9]/.test(pw.value)  ? '#16a34a' : '#6b7280';
  });
</script>
