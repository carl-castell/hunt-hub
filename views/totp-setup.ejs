<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hunt-Hub | Set Up Two-Factor Authentication</title>
    <link rel="stylesheet" href="/css/style.css?v=1" />
  </head>
  <body class="centered-page">
    <div class="card centered-card">
      <h1>Hunt-Hub</h1>
      <p>Set up two-factor authentication for your admin account</p>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <p style="margin-bottom: 0.5rem;">Scan this QR code with your authenticator app (Google Authenticator, Authy, etc.):</p>
      <div style="text-align: center; margin: 1rem 0;">
        <img src="<%= qrDataUrl %>" alt="TOTP QR Code" style="width: 200px; height: 200px;" />
      </div>

      <details style="margin-bottom: 1rem;">
        <summary style="cursor: pointer; font-size: 0.875rem;">Can't scan? Enter the code manually</summary>
        <code style="display: block; margin-top: 0.5rem; word-break: break-all; font-size: 0.8rem; background: #f0f0f0; padding: 0.5rem; border-radius: 4px;"><%= secret %></code>
      </details>

      <form action="/totp/setup" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label for="token">Enter the 6-digit code to confirm setup</label>
          <input
            type="text"
            id="token"
            name="token"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            autocomplete="one-time-code"
            required
            autofocus
          />
        </div>
        <button type="submit" class="btn-confirm btn-full">Confirm & Log In</button>
      </form>

      <form action="/login" method="GET" style="margin-top: 1rem;">
        <button type="submit" class="btn-cancel btn-full">Back to Login</button>
      </form>
    </div>
  </body>
</html>
