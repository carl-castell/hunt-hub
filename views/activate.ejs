<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Hunt-Hub | Activate Account</title>
  <link rel="stylesheet" href="/css/style.css?v=1" />
</head>
<body>

  <header>
    <h1>Hunt-Hub <span style="font-weight:300; font-size:1rem;">Account Activation</span></h1>
  </header>

  <div class="content">
    <div class="card">
      <h2 style="margin-bottom: 20px; font-size: 1.4rem; color: #222;">Set your password</h2>

      <% if (error) { %>
        <p style="color: #e53e3e; margin-bottom: 16px; font-size: 0.9rem;"><%= error %></p>
      <% } %>

      <form action="/activate/<%= token %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Enter password" required />
          <ul id="pw-hints" style="list-style:none; padding:0; margin:6px 0 0; font-size:0.82rem;">
            <li id="hint-length"  style="color:#6b7280">✓ At least 8 characters</li>
            <li id="hint-upper"   style="color:#6b7280">✓ One uppercase letter</li>
            <li id="hint-number"  style="color:#6b7280">✓ One number</li>
            <li id="hint-special" style="color:#6b7280">✓ One special character</li>
          </ul>
        </div>
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" required />
        </div>
        <div style="margin-top: 24px;">
          <button type="submit" class="btn-confirm">Activate Account</button>
        </div>
      </form>
    </div>
  </div>

<script>
  const pw = document.getElementById('password');
  const hl = document.getElementById('hint-length');
  const hu = document.getElementById('hint-upper');
  const hn = document.getElementById('hint-number');
  const hs = document.getElementById('hint-special');
  pw.addEventListener('input', function () {
    hl.style.color = pw.value.length >= 8            ? '#16a34a' : '#6b7280';
    hu.style.color = /[A-Z]/.test(pw.value)          ? '#16a34a' : '#6b7280';
    hn.style.color = /[0-9]/.test(pw.value)          ? '#16a34a' : '#6b7280';
    hs.style.color = /[^a-zA-Z0-9]/.test(pw.value)  ? '#16a34a' : '#6b7280';
  });
</script>
</body>
</html>
